<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mrpt_opengl</name>
  <version>3.0.3</version>
  <description>The MRPT C++ library mrpt_opengl</description>

  <maintainer email="joseluisblancoc@gmail.com">Jose-Luis Blanco-Claraco</maintainer>
  <license file="LICENSE">BSD</license>

  <url type="website">https://github.com/MRPT/</url>

  <buildtool_depend>cmake</buildtool_depend>

  <depend>mrpt_viz</depend>
  <depend>mrpt_poses</depend>
  <depend>mrpt_img</depend>

  <build_depend>eigen</build_depend>

  <depend>opengl</depend> <!-- Use the all-3 depend not to rely on debian sh-libs to actually add opengl libs binaries downstream -->

  <export>
    <build_type>cmake</build_type>
  </export>

</package>
