<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mrpt_hwdrivers</name>
  <version>3.0.4</version>
  <description>The MRPT C++ library mrpt_hwdrivers</description>

  <maintainer email="joseluisblancoc@gmail.com">Jose-Luis Blanco-Claraco</maintainer>
  <license file="LICENSE">BSD</license>

  <url type="website">https://github.com/MRPT/</url>

  <buildtool_depend>cmake</buildtool_depend>

  <depend>mrpt_comms</depend>
  <depend>mrpt_maps</depend>
  <depend>mrpt_viz</depend>

  <!-- Optional dependencies, auto-detected by CMake scripts at build time -->
  <build_depend>libavcodec-dev</build_depend>
  <build_depend>libavformat-dev</build_depend>
  <build_depend>libavutil-dev</build_depend>
  <build_depend>libswscale-dev</build_depend>
  <build_depend>libdc1394-dev</build_depend>
  <build_depend>libopenni2-dev</build_depend>
  <build_depend>libpcap-dev</build_depend>
  <build_depend>libusb-1.0-0-dev</build_depend>

  <export>
    <build_type>cmake</build_type>
  </export>

</package>
